# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://hgapp:change_me@db:5432/hgapp

# ── Security ─────────────────────────────────────────────────────────────────
# JWT secret — run: openssl rand -hex 32
SECRET_KEY=change_me_32_hex_chars
# Fernet key for encrypting PS API keys — run: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_fernet_key

# ── Admin bootstrap ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

# ── LiteLLM proxy ─────────────────────────────────────────────────────────────
LITELLM_BASE_URL=http://litellm:4000
LITELLM_MASTER_KEY=change_me_litellm_key

# ── LLM provider keys (used by LiteLLM) ──────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=       # only needed for free models

# ── App settings ──────────────────────────────────────────────────────────────
DEFAULT_DAILY_LIMIT=50
MAX_FILE_SIZE_MB=10
